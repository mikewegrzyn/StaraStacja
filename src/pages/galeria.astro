---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const galleryItems = [
  // === WIDOKI / VIEWS — the wow factor, mountain + building ===
  { src: '/images/gallery/aerial-panorama.jpg', alt: 'Stara Stacja z lotu ptaka — panorama Szyndzielni', category: 'widoki', featured: true },
  { src: '/images/gallery/exterior-summer.jpg', alt: 'Restauracja latem — taras z widokiem na góry', category: 'widoki' },
  { src: '/images/gallery/aerial-winter.jpg', alt: 'Widok z drona — zimowy szczyt Szyndzielni', category: 'widoki' },
  { src: '/images/gallery/winter-path.jpg', alt: 'Zimowa ścieżka do restauracji', category: 'widoki' },
  { src: '/images/cablecar.jpg', alt: 'Kolejka linowa na Szyndzielnię', category: 'widoki' },

  // === WNĘTRZE / INTERIOR — the space, character, gondola ===
  { src: '/images/gallery/gondola-interior.jpg', alt: 'Sala z zabytkową gondolą kolejki linowej', category: 'wnętrze', featured: true },
  { src: '/images/gallery/dining-hall.jpg', alt: 'Główna sala restauracji', category: 'wnętrze' },
  { src: '/images/gallery/table-setting.jpg', alt: 'Elegancka nakrycie stołu ze słonecznikami', category: 'wnętrze' },
  { src: '/images/gallery/chef-flambe.jpg', alt: 'Szef kuchni przy pracy — flambowanie', category: 'wnętrze' },
  { src: '/images/interior.jpg', alt: 'Wnętrze restauracji', category: 'wnętrze' },

  // === KUCHNIA / FOOD — the dishes ===
  { src: '/images/gallery/potato-pancakes.jpg', alt: 'Placki ziemniaczane z ziołowym sosem', category: 'kuchnia', featured: true },
  { src: '/images/gallery/pear-dessert.jpg', alt: 'Gruszka w kruszonkowej panierce z karmelem', category: 'kuchnia' },
  { src: '/images/gallery/pizza-margherita.jpg', alt: 'Pizza Margherita z pieca', category: 'kuchnia' },
  { src: '/images/gallery/filo-tartlet.jpg', alt: 'Tartaletka z grzybami i jajkiem', category: 'kuchnia' },
  { src: '/images/gallery/soup-bread.jpg', alt: 'Zupa pomidorowa z rozmarynem i grzankami', category: 'kuchnia' },
  { src: '/images/gallery/schnitzel-platter.jpg', alt: 'Sznycel z pieczonymi warzywami', category: 'kuchnia' },
  { src: '/images/gallery/pierogi.jpg', alt: 'Pierogi zapiekane ze śmietaną i szczypiorkiem', category: 'kuchnia' },
  { src: '/images/gallery/caesar-salad.jpg', alt: 'Sałatka z grillowanym kurczakiem', category: 'kuchnia' },
  { src: '/images/gallery/pear-sorbet.jpg', alt: 'Gruszka z sorbetem malinowym', category: 'kuchnia' },
  { src: '/images/gallery/pulled-meat.jpg', alt: 'Duszone mięso z ziołami', category: 'kuchnia' },
  { src: '/images/gallery/schnitzel.jpg', alt: 'Tradycyjny kotlet schabowy', category: 'kuchnia' },

  // === EVENTY / EVENTS — weddings, parties ===
  { src: '/images/gallery/wedding-setup.jpg', alt: 'Sala weselna — eleganckie nakrycie ze świeżymi kwiatami', category: 'eventy', featured: true },
  { src: '/images/gallery/festive-table.jpg', alt: 'Świąteczna dekoracja stołu', category: 'eventy' },
  { src: '/images/gallery/event-crowd.jpg', alt: 'Wydarzenie w restauracji — pełna sala gości', category: 'eventy' },
  { src: '/images/gallery/herring-buffet.jpg', alt: 'Catering — śledzie i zimne przekąski', category: 'eventy' },
];

const categories = [
  { id: 'wszystko', label: 'Wszystko' },
  { id: 'widoki', label: 'Widoki' },
  { id: 'wnętrze', label: 'Wnętrze' },
  { id: 'kuchnia', label: 'Kuchnia' },
  { id: 'eventy', label: 'Eventy' },
];
---

<Layout title="Galeria — Stara Stacja" description="Zdjęcia restauracji Stara Stacja — widoki z góry Szyndzielnia, wnętrza, dania i eventy.">
  <Nav />

  <!-- Hero header with background image -->
  <section class="relative pt-32 pb-24 px-6 bg-primary text-white overflow-hidden">
    <div class="absolute inset-0 bg-[url('/images/gallery/aerial-panorama.jpg')] bg-cover bg-center opacity-20"></div>
    <div class="relative max-w-4xl mx-auto text-center">
      <p class="text-accent-light uppercase tracking-[0.15em] sm:tracking-[0.3em] text-xs sm:text-sm mb-4">Stara Stacja</p>
      <h1 class="font-heading text-4xl sm:text-5xl md:text-6xl font-bold mb-4">Galeria</h1>
      <p class="text-white/60 max-w-xl mx-auto">Odkryj piękno Starej Stacji na szczycie Szyndzielni — widoki, wnętrza, smaki i wyjątkowe chwile</p>
    </div>
  </section>

  <!-- Category filter -->
  <div class="sticky top-20 z-40 bg-cream/95 backdrop-blur-sm border-b border-cream-dark">
    <div class="max-w-6xl mx-auto px-6 py-3 flex gap-2 sm:gap-4 justify-center flex-wrap">
      {categories.map((cat) => (
        <button
          data-filter={cat.id}
          class:list={[
            'gallery-filter text-xs uppercase tracking-widest transition-all font-medium cursor-pointer px-4 py-2 min-h-[44px] rounded-full',
            cat.id === 'wszystko' ? 'bg-primary text-white' : 'text-dark/50 hover:text-primary hover:bg-cream-dark',
          ]}
        >
          {cat.label}
        </button>
      ))}
    </div>
  </div>

  <!-- Gallery grid -->
  <section class="py-12 sm:py-16 px-4 sm:px-6 bg-cream">
    <div class="max-w-7xl mx-auto">
      <div id="gallery-grid" class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-2 sm:gap-3">
        {galleryItems.map((item, i) => (
          <a
            href={item.src}
            target="_blank"
            class:list={[
              'gallery-item group relative overflow-hidden bg-primary/10 cursor-pointer block',
              item.featured ? 'col-span-2 row-span-2' : '',
              item.featured ? 'aspect-square' : 'aspect-[4/3]',
            ]}
            data-category={item.category}
          >
            <img
              src={item.src}
              alt={item.alt}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading={i < 6 ? 'eager' : 'lazy'}
            />
            <div class="absolute inset-0 bg-gradient-to-t from-dark/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            <div class="absolute bottom-0 left-0 right-0 p-3 sm:p-4 translate-y-full group-hover:translate-y-0 transition-transform duration-300">
              <p class="text-white text-xs sm:text-sm font-medium drop-shadow-lg">{item.alt}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="py-12 px-6 bg-primary text-white">
    <div class="max-w-5xl mx-auto grid grid-cols-2 sm:grid-cols-4 gap-8 text-center">
      <div>
        <p class="font-heading text-3xl sm:text-4xl font-bold text-accent">1000m</p>
        <p class="text-white/50 text-sm mt-1">n.p.m.</p>
      </div>
      <div>
        <p class="font-heading text-3xl sm:text-4xl font-bold text-accent">240</p>
        <p class="text-white/50 text-sm mt-1">miejsc</p>
      </div>
      <div>
        <p class="font-heading text-3xl sm:text-4xl font-bold text-accent">120</p>
        <p class="text-white/50 text-sm mt-1">na tarasie</p>
      </div>
      <div>
        <p class="font-heading text-3xl sm:text-4xl font-bold text-accent">360°</p>
        <p class="text-white/50 text-sm mt-1">panorama</p>
      </div>
    </div>
  </section>

  <!-- CTA for Instagram -->
  <section class="py-16 px-6 bg-cream-dark">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-dark/60 mb-4">Więcej zdjęć znajdziesz na naszym Instagramie</p>
      <a href="https://instagram.com/stara.stacja" target="_blank" rel="noopener" class="inline-block px-8 py-4 bg-primary text-white font-semibold uppercase tracking-wider text-sm hover:bg-primary-light transition-colors">
        @stara.stacja
      </a>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  const filters = document.querySelectorAll('.gallery-filter');
  const items = document.querySelectorAll('.gallery-item');

  filters.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = (btn as HTMLElement).dataset.filter;

      // Update active filter style
      filters.forEach((f) => {
        f.classList.remove('bg-primary', 'text-white');
        f.classList.add('text-dark/50');
      });
      btn.classList.add('bg-primary', 'text-white');
      btn.classList.remove('text-dark/50');

      // Filter items with fade animation
      items.forEach((item) => {
        const el = item as HTMLElement;
        if (filter === 'wszystko' || el.dataset.category === filter) {
          el.style.display = '';
          el.animate([
            { opacity: 0, transform: 'scale(0.95)' },
            { opacity: 1, transform: 'scale(1)' },
          ], { duration: 300, easing: 'ease-out' });
        } else {
          el.style.display = 'none';
        }
      });
    });
  });
</script>
