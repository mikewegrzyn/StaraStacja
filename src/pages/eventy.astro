---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Eventy — Stara Stacja" description="Wesela, komunie i inne wydarzenia na szczycie Szyndzielni. Sala na 120 osób z panoramicznym widokiem na Beskidy.">
  <Nav />

  <!-- Hero -->
  <section class="relative pt-32 pb-20 px-6 bg-primary text-white">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-accent-light uppercase tracking-[0.15em] sm:tracking-[0.3em] text-xs sm:text-sm mb-4">Stara Stacja</p>
      <h1 class="font-heading text-5xl md:text-6xl font-bold mb-4">
        <span class="text-pl">Eventy i Uroczystości</span>
        <span class="text-en hidden">Events & Celebrations</span>
        <span class="text-cs hidden">Akce a Oslavy</span>
      </h1>
      <p class="text-white/60 max-w-xl mx-auto">
        <span class="text-pl">Niezapomniane wydarzenia na 1000 metrów nad poziomem morza</span>
        <span class="text-en hidden">Unforgettable events at 1,000 meters above sea level</span>
        <span class="text-cs hidden">Nezapomenutelné akce v 1 000 metrech nad mořem</span>
      </p>
    </div>
  </section>

  <!-- Event cards -->
  <section class="py-24 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-primary mb-4">
          <span class="text-pl">Wybierz typ wydarzenia</span>
          <span class="text-en hidden">Choose your event</span>
          <span class="text-cs hidden">Vyberte si typ akce</span>
        </h2>
        <p class="text-dark/60 max-w-2xl mx-auto">
          <span class="text-pl">Profesjonalna obsługa, wspaniała kuchnia i wyjątkowa przestrzeń dawnej stacji kolejki linowej — idealne miejsce na każdą uroczystość.</span>
          <span class="text-en hidden">Professional service, wonderful cuisine, and the unique space of a former cable car station — the perfect venue for any celebration.</span>
          <span class="text-cs hidden">Profesionální obsluha, skvělá kuchyně a jedinečný prostor bývalé stanice lanovky — ideální místo pro jakoukoli oslavu.</span>
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Wesela -->
        <a href="/wesela" class="group relative overflow-hidden rounded-sm aspect-[4/3]">
          <div class="absolute inset-0 bg-[url('/images/wedding/wedding-79.jpg')] bg-cover bg-center group-hover:scale-105 transition-transform duration-700"></div>
          <div class="absolute inset-0 bg-gradient-to-t from-primary/90 via-primary/40 to-transparent"></div>
          <div class="absolute inset-0 flex flex-col justify-end p-8 md:p-10">
            <p class="text-accent uppercase tracking-[0.2em] text-xs mb-2">Stara Stacja Weddings</p>
            <h3 class="font-heading text-3xl md:text-4xl font-bold text-white mb-3">
              <span class="text-pl">Wesela</span>
              <span class="text-en hidden">Weddings</span>
              <span class="text-cs hidden">Svatby</span>
            </h3>
            <p class="text-white/70 text-sm mb-4 max-w-md">
              <span class="text-pl">Sala na 120 osób, ceremonia w plenerze, historyczne wagoniki, kolejka linowa w cenie. Pakiety od 349 zł/os.</span>
              <span class="text-en hidden">Hall for 120 guests, outdoor ceremony, historic gondolas, cable car included. Packages from 349 PLN/person.</span>
              <span class="text-cs hidden">Sál pro 120 hostů, obřad venku, historické kabinky, lanovka v ceně. Balíčky od 349 PLN/os.</span>
            </p>
            <span class="inline-flex items-center text-accent font-semibold uppercase tracking-wider text-sm group-hover:gap-3 gap-2 transition-all">
              <span class="text-pl">Zobacz ofertę</span>
              <span class="text-en hidden">View offer</span>
              <span class="text-cs hidden">Zobrazit nabídku</span>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </span>
          </div>
        </a>

        <!-- Komunie -->
        <a href="/komunie" class="group relative overflow-hidden rounded-sm aspect-[4/3]">
          <div class="absolute inset-0 bg-[url('/images/wedding/wedding-31.jpg')] bg-cover bg-center group-hover:scale-105 transition-transform duration-700"></div>
          <div class="absolute inset-0 bg-gradient-to-t from-primary/90 via-primary/40 to-transparent"></div>
          <div class="absolute inset-0 flex flex-col justify-end p-8 md:p-10">
            <p class="text-accent uppercase tracking-[0.2em] text-xs mb-2">Stara Stacja</p>
            <h3 class="font-heading text-3xl md:text-4xl font-bold text-white mb-3">
              <span class="text-pl">Komunie</span>
              <span class="text-en hidden">First Communions</span>
              <span class="text-cs hidden">První svaté přijímání</span>
            </h3>
            <p class="text-white/70 text-sm mb-4 max-w-md">
              <span class="text-pl">Menu serwowane lub szwedzki stół, dania dla dzieci i dorosłych, patera ciast i owoców. Od 180 zł/os.</span>
              <span class="text-en hidden">Served menu or buffet, meals for children and adults, cake and fruit platters. From 180 PLN/person.</span>
              <span class="text-cs hidden">Servírované menu nebo švédský stůl, jídla pro děti i dospělé, mísa dortů a ovoce. Od 180 PLN/os.</span>
            </p>
            <span class="inline-flex items-center text-accent font-semibold uppercase tracking-wider text-sm group-hover:gap-3 gap-2 transition-all">
              <span class="text-pl">Zobacz ofertę</span>
              <span class="text-en hidden">View offer</span>
              <span class="text-cs hidden">Zobrazit nabídku</span>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Why us -->
  <section class="py-24 px-6 bg-primary text-white">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="font-heading text-3xl md:text-4xl font-bold">
          <span class="text-pl">Dlaczego Stara Stacja?</span>
          <span class="text-en hidden">Why Stara Stacja?</span>
          <span class="text-cs hidden">Proč Stará Stacja?</span>
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 text-center">
        <div>
          <p class="font-heading text-4xl font-bold text-accent mb-2">300m²</p>
          <p class="text-white/60 text-sm">
            <span class="text-pl">Sala z panoramicznym widokiem</span>
            <span class="text-en hidden">Hall with panoramic views</span>
            <span class="text-cs hidden">Sál s panoramatickým výhledem</span>
          </p>
        </div>
        <div>
          <p class="font-heading text-4xl font-bold text-accent mb-2">120</p>
          <p class="text-white/60 text-sm">
            <span class="text-pl">Miejsc wewnątrz</span>
            <span class="text-en hidden">Indoor seats</span>
            <span class="text-cs hidden">Míst uvnitř</span>
          </p>
        </div>
        <div>
          <p class="font-heading text-4xl font-bold text-accent mb-2">1000m</p>
          <p class="text-white/60 text-sm">
            <span class="text-pl">Nad poziomem morza</span>
            <span class="text-en hidden">Above sea level</span>
            <span class="text-cs hidden">Nad mořem</span>
          </p>
        </div>
        <div>
          <p class="font-heading text-4xl font-bold text-accent mb-2">1953</p>
          <p class="text-white/60 text-sm">
            <span class="text-pl">Rok powstania stacji</span>
            <span class="text-en hidden">Year the station was built</span>
            <span class="text-cs hidden">Rok založení stanice</span>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Other events -->
  <section class="py-24 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-primary mb-4">
        <span class="text-pl">Inne wydarzenia</span>
        <span class="text-en hidden">Other events</span>
        <span class="text-cs hidden">Další akce</span>
      </h2>
      <p class="text-dark/60 max-w-2xl mx-auto mb-10">
        <span class="text-pl">Organizujemy również konferencje, szkolenia, spotkania firmowe i inne uroczystości. Możemy dostosować ofertę do Waszych potrzeb i zorganizować transport kolejką linową.</span>
        <span class="text-en hidden">We also organize conferences, training sessions, corporate meetings, and other celebrations. We can tailor our offer to your needs and arrange cable car transport.</span>
        <span class="text-cs hidden">Pořádáme také konference, školení, firemní setkání a další oslavy. Nabídku přizpůsobíme vašim potřebám a zajistíme dopravu lanovkou.</span>
      </p>
      <a href="/kontakt" class="inline-block px-10 py-4 bg-primary text-white font-semibold uppercase tracking-wider text-sm hover:bg-primary-light transition-colors">
        <span class="text-pl">Skontaktuj się z nami</span>
        <span class="text-en hidden">Contact us</span>
        <span class="text-cs hidden">Kontaktujte nás</span>
      </a>
    </div>
  </section>

  <Footer />
</Layout>
