---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import info from '../data/info.json';
---

<Layout>
  <Nav />

  <!-- Hero -->
  <section class="relative h-screen flex items-center justify-center overflow-hidden">
    <!-- Static fallback (loads first, always visible on mobile) -->
    <div class="absolute inset-0 bg-gradient-to-br from-primary via-primary-light to-accent/40"></div>
    <div class="absolute inset-0 bg-[url('/images/hero.jpg')] bg-cover bg-[center_40%] bg-no-repeat"></div>

    <!-- Video carousel background -->
    <video
      id="hero-video-0"
      class="hero-video absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-1000"
      autoplay
      muted
      playsinline
      preload="auto"
      poster="/images/hero.jpg"
    >
      <source src="/images/hero-bg.mp4" type="video/mp4" />
    </video>
    <video
      id="hero-video-1"
      class="hero-video absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-1000"
      muted
      playsinline
      preload="auto"
    >
      <source src="/images/hero-bg-seasons.mp4" type="video/mp4" />
    </video>

    <div class="absolute inset-0 bg-dark-overlay"></div>

    <div class="relative z-10 text-center text-white px-6 max-w-4xl">
      <p class="text-accent-light uppercase tracking-[0.15em] sm:tracking-[0.3em] text-xs sm:text-sm mb-6 animate-fade-in">
        <span class="text-pl">Restauracja na szczycie Szyndzielni</span>
        <span class="text-en hidden">Restaurant at the summit of Szyndzielnia</span>
        <span class="text-cs hidden">Restaurace na vrcholu Szyndzielnie</span>
      </p>
      <h1 class="font-heading text-4xl sm:text-5xl md:text-7xl lg:text-8xl font-bold mb-6">
        Stara Stacja
      </h1>
      <p class="text-xl md:text-2xl font-light text-white/80 mb-10">
        <span class="text-pl">{info.tagline}</span>
        <span class="text-en hidden">1,000 meters above sea level</span>
        <span class="text-cs hidden">1 000 metrů nad mořem</span>
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/menu" class="px-8 py-4 bg-accent text-primary font-semibold uppercase tracking-wider text-sm hover:bg-accent-light transition-colors">
          <span class="text-pl">Zobacz menu</span>
          <span class="text-en hidden">View menu</span>
          <span class="text-cs hidden">Zobrazit menu</span>
        </a>
        <a href="/rezerwacje" class="px-8 py-4 border-2 border-white/40 text-white font-semibold uppercase tracking-wider text-sm hover:bg-white/10 transition-colors">
          <span class="text-pl">Rezerwuj stolik</span>
          <span class="text-en hidden">Book a table</span>
          <span class="text-cs hidden">Rezervovat stůl</span>
        </a>
      </div>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </section>

  <!-- About -->
  <section class="py-24 px-6">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
      <div>
        <p class="text-accent uppercase tracking-[0.2em] text-sm mb-3">
          <span class="text-pl">O nas</span>
          <span class="text-en hidden">About us</span>
          <span class="text-cs hidden">O nás</span>
        </p>
        <h2 class="font-heading text-4xl md:text-5xl font-bold text-primary mb-6">
          <span class="text-pl">Wyjątkowe miejsce na mapie Bielska</span>
          <span class="text-en hidden">A unique place on the map of Bielsko</span>
          <span class="text-cs hidden">Výjimečné místo na mapě Bielska</span>
        </h2>
        <p class="text-dark/70 leading-relaxed mb-6">
          <span class="text-pl">Stara Stacja to restauracja z duszą, położona na szczycie góry Szyndzielnia (1000 m n.p.m.) w sercu Beskidu Śląskiego. Łączymy tradycyjną kuchnię regionalną z nowoczesnymi technikami kulinarnymi, oferując niezapomniane doznania smakowe z panoramicznym widokiem na góry. Nasz budynek to dawna stacja kolejki linowej, która zyskała nowe życie jako przestrzeń gastronomiczna z charakterem.</span>
          <span class="text-en hidden">Stara Stacja is a restaurant with soul, located at the summit of Mount Szyndzielnia (1,000 m a.s.l.) in the heart of the Silesian Beskids. We combine traditional regional cuisine with modern culinary techniques, offering unforgettable flavors with a panoramic mountain view. Our building is a former cable car station that has gained new life as a dining space with character.</span>
          <span class="text-cs hidden">Stara Stacja je restaurace s duší na vrcholu hory Szyndzielnia (1 000 m n. m.) v srdci Slezských Beskyd. Kombinujeme tradiční regionální kuchyni s moderními kulinářskými technikami a nabízíme nezapomenutelné chuťové zážitky s panoramatickým výhledem na hory. Naše budova je bývalá stanice lanovky, která získala nový život jako gastronomický prostor s charakterem.</span>
        </p>
        <p class="text-dark/70 leading-relaxed mb-6">
          <span class="text-pl">Szyndzielnia to serce górskiej turystyki w Bielsku-Białej. Ze szczytu rozchodzą się popularne szlaki na Klimczok, Błatnią i dalej w Beskid Śląski — idealne na jednodniowe wycieczki piesze i trailowe wyprawy. Dzięki kolejce linowej na szczyt dostaniesz się wygodnie w kilka minut, co czyni to miejsce doskonałym punktem startowym dla turystów w każdym wieku — od rodzin z dziećmi po doświadczonych wędrowców.</span>
          <span class="text-en hidden">Szyndzielnia is the heart of mountain tourism in Bielsko-Biała. From the summit, popular hiking trails lead to Klimczok, Błatnia, and deeper into the Silesian Beskids — perfect for day hikes and trail adventures. Thanks to the cable car, you can reach the top comfortably in just a few minutes, making it an excellent starting point for hikers of all ages — from families with children to experienced trekkers.</span>
          <span class="text-cs hidden">Szyndzielnia je srdcem horské turistiky v Bielsku-Bílé. Z vrcholu vedou oblíbené turistické stezky na Klimczok, Błatnii a dále do Slezských Beskyd — ideální na jednodenní pěší túry a trailové výpravy. Díky lanovce se na vrchol dostanete pohodlně za pár minut, což z něj činí vynikající výchozí bod pro turisty všech věkových kategorií — od rodin s dětmi po zkušené turisty.</span>
        </p>
        <p class="text-dark/70 leading-relaxed mb-8">
          <span class="text-pl">Region jest również kultowym miejscem dla społeczności MTB — sieć tras enduro i cross-country przyciąga rowerzystów górskich z całej Polski i zza granicy. Po intensywnym dniu na szlakach lub trasach rowerowych Stara Stacja to idealne miejsce na regenerację z pysznym jedzeniem i widokami na Beskidy.</span>
          <span class="text-en hidden">The region is also an iconic destination for the MTB community — a network of enduro and cross-country trails attracts mountain bikers from across Poland and beyond. After an intense day on the hiking trails or bike routes, Stara Stacja is the perfect place to recharge with delicious food and Beskid mountain views.</span>
          <span class="text-cs hidden">Region je také kultovním místem pro komunitu MTB — síť enduro a cross-country tras přitahuje horské cyklisty z celého Polska i ze zahraničí. Po intenzivním dni na turistických stezkách nebo cyklistických trasách je Stara Stacja ideálním místem k regeneraci s vynikajícím jídlem a výhledy na Beskydy.</span>
        </p>
        <a href="/kontakt" class="inline-block text-accent font-semibold uppercase tracking-wider text-sm border-b-2 border-accent pb-1 hover:text-primary hover:border-primary transition-colors">
          <span class="text-pl">Dowiedz się więcej →</span>
          <span class="text-en hidden">Learn more →</span>
          <span class="text-cs hidden">Zjistit více →</span>
        </a>
      </div>
      <div class="relative">
        <div class="aspect-[4/5] bg-gradient-to-br from-cream-dark to-accent/20 rounded-sm overflow-hidden">
          <div class="w-full h-full bg-[url('/images/interior.jpg')] bg-cover bg-center"></div>
        </div>
        <div class="absolute -bottom-6 left-0 sm:-left-6 bg-accent text-primary px-4 sm:px-6 py-3 sm:py-4 font-heading text-base sm:text-lg font-bold">
          <span class="text-pl">240 miejsc</span>
          <span class="text-en hidden">240 seats</span>
          <span class="text-cs hidden">240 míst</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-24 px-6 bg-primary text-white">
    <div class="max-w-6xl mx-auto text-center mb-16">
      <p class="text-accent uppercase tracking-[0.2em] text-sm mb-3">
        <span class="text-pl">Dlaczego my</span>
        <span class="text-en hidden">Why us</span>
        <span class="text-cs hidden">Proč my</span>
      </p>
      <h2 class="font-heading text-4xl md:text-5xl font-bold">
        <span class="text-pl">Co nas wyróżnia</span>
        <span class="text-en hidden">What makes us special</span>
        <span class="text-cs hidden">Co nás odlišuje</span>
      </h2>
    </div>
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-12">
      <div class="text-center">
        <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-accent/20 flex items-center justify-center">
          <svg class="w-8 h-8 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h3 class="font-heading text-xl font-semibold mb-3">
          <span class="text-pl">Widoki na 1000m</span>
          <span class="text-en hidden">Views at 1000m</span>
          <span class="text-cs hidden">Výhledy z 1000m</span>
        </h3>
        <p class="text-white/60 text-sm leading-relaxed">
          <span class="text-pl">Panoramiczny widok na Beskidy z tarasu restauracji. Jedz i podziwiaj góry.</span>
          <span class="text-en hidden">Panoramic view of the Beskid Mountains from the restaurant terrace. Dine and admire the mountains.</span>
          <span class="text-cs hidden">Panoramatický výhled na Beskydy z terasy restaurace. Jezte a obdivujte hory.</span>
        </p>
      </div>
      <div class="text-center">
        <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-accent/20 flex items-center justify-center">
          <svg class="w-8 h-8 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
          </svg>
        </div>
        <h3 class="font-heading text-xl font-semibold mb-3">
          <span class="text-pl">Kuchnia regionalna</span>
          <span class="text-en hidden">Regional cuisine</span>
          <span class="text-cs hidden">Regionální kuchyně</span>
        </h3>
        <p class="text-white/60 text-sm leading-relaxed">
          <span class="text-pl">Tradycyjne smaki Podbeskidzia w nowoczesnym wydaniu. Lokalne składniki, autorskie przepisy.</span>
          <span class="text-en hidden">Traditional flavors of the Podbeskidzie region in a modern style. Local ingredients, original recipes.</span>
          <span class="text-cs hidden">Tradiční chutě regionu Podbeskydí v moderním pojetí. Lokální suroviny, autorské recepty.</span>
        </p>
      </div>
      <div class="text-center">
        <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-accent/20 flex items-center justify-center">
          <svg class="w-8 h-8 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
          </svg>
        </div>
        <h3 class="font-heading text-xl font-semibold mb-3">
          <span class="text-pl">Eventy i wesela</span>
          <span class="text-en hidden">Events & weddings</span>
          <span class="text-cs hidden">Akce a svatby</span>
        </h3>
        <p class="text-white/60 text-sm leading-relaxed">
          <span class="text-pl">240 miejsc, 120 na tarasie. Organizujemy wesela, konferencje i spotkania firmowe.</span>
          <span class="text-en hidden">240 seats, 120 on the terrace. We host weddings, conferences, and corporate events.</span>
          <span class="text-cs hidden">240 míst, 120 na terase. Pořádáme svatby, konference a firemní akce.</span>
        </p>
      </div>
    </div>
  </section>

  <!-- Menu preview -->
  <section class="py-24 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-accent uppercase tracking-[0.2em] text-sm mb-3">
        <span class="text-pl">Smaki Szyndzielni</span>
        <span class="text-en hidden">Flavors of Szyndzielnia</span>
        <span class="text-cs hidden">Chutě Szyndzielnie</span>
      </p>
      <h2 class="font-heading text-4xl md:text-5xl font-bold text-primary mb-6">
        <span class="text-pl">Nasze menu</span>
        <span class="text-en hidden">Our menu</span>
        <span class="text-cs hidden">Naše menu</span>
      </h2>
      <p class="text-dark/60 max-w-2xl mx-auto mb-12">
        <span class="text-pl">Od tradycyjnych smaków górskich po nowoczesne dania europejskie — nasze menu łączy to, co najlepsze z regionalnej i międzynarodowej kuchni.</span>
        <span class="text-en hidden">From traditional mountain flavors to modern European dishes — our menu combines the best of regional and international cuisine.</span>
        <span class="text-cs hidden">Od tradičních horských chutí po moderní evropská jídla — naše menu kombinuje to nejlepší z regionální a mezinárodní kuchyně.</span>
      </p>
      <a href="/menu" class="inline-block px-10 py-4 bg-primary text-white font-semibold uppercase tracking-wider text-sm hover:bg-primary-light transition-colors">
        <span class="text-pl">Pełne menu</span>
        <span class="text-en hidden">Full menu</span>
        <span class="text-cs hidden">Celé menu</span>
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-32 px-6 overflow-hidden">
    <div class="absolute inset-0 bg-[url('/images/cablecar.jpg')] bg-cover bg-[center_94%] md:bg-fixed"></div>
    <div class="absolute inset-0 bg-dark-overlay"></div>
    <div class="relative z-10 max-w-3xl mx-auto text-center text-white">
      <h2 class="font-heading text-4xl md:text-5xl font-bold mb-6">
        <span class="text-pl">Zarezerwuj stolik</span>
        <span class="text-en hidden">Book a table</span>
        <span class="text-cs hidden">Rezervujte stůl</span>
      </h2>
      <p class="text-white/70 text-lg mb-10">
        <span class="text-pl">Zadzwoń lub napisz do nas, aby zarezerwować stolik z widokiem na góry. Możemy również zorganizować transport kolejką linową.</span>
        <span class="text-en hidden">Call or write to us to book a table with a mountain view. We can also arrange cable car transport.</span>
        <span class="text-cs hidden">Zavolejte nebo nám napište a rezervujte si stůl s výhledem na hory. Můžeme také zajistit dopravu lanovkou.</span>
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={`tel:${info.phone}`} class="px-8 py-4 bg-accent text-primary font-semibold uppercase tracking-wider text-sm hover:bg-accent-light transition-colors">
          {info.phone}
        </a>
        <a href="/rezerwacje" class="px-8 py-4 border-2 border-white/40 text-white font-semibold uppercase tracking-wider text-sm hover:bg-white/10 transition-colors">
          <span class="text-pl">Więcej informacji</span>
          <span class="text-en hidden">More information</span>
          <span class="text-cs hidden">Více informací</span>
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fade-in 1s ease-out;
  }
</style>

<script>
  const videos = [
    document.getElementById('hero-video-0') as HTMLVideoElement,
    document.getElementById('hero-video-1') as HTMLVideoElement,
  ];
  let current = 0;

  function showVideo(index: number) {
    videos[index].currentTime = 0;
    videos[index].play();
    videos[index].classList.remove('opacity-0');
    videos[index].classList.add('opacity-100');
  }

  function hideVideo(index: number) {
    videos[index].classList.remove('opacity-100');
    videos[index].classList.add('opacity-0');
  }

  function crossfade() {
    const next = (current + 1) % videos.length;
    showVideo(next);
    hideVideo(current);
    current = next;
  }

  // When a video ends, crossfade to the next one
  videos.forEach((v) => {
    v.addEventListener('ended', crossfade);
  });

  // Start first video once loaded
  const first = videos[0];
  if (first) {
    const onReady = () => showVideo(0);
    if (first.readyState >= 4) {
      onReady();
    } else {
      first.addEventListener('canplaythrough', onReady, { once: true });
    }
  }
</script>
