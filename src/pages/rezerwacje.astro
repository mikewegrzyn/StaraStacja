---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import info from '../data/info.json';
---

<Layout title="Rezerwacje — Stara Stacja" description="Zarezerwuj stolik w restauracji Stara Stacja na szczycie Szyndzielni.">
  <Nav />

  <section class="relative pt-32 pb-20 px-6 bg-primary text-white">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-accent-light uppercase tracking-[0.15em] sm:tracking-[0.3em] text-xs sm:text-sm mb-4">Stara Stacja</p>
      <h1 class="font-heading text-5xl md:text-6xl font-bold mb-4">Rezerwacje</h1>
      <p class="text-white/60 max-w-xl mx-auto">Zarezerwuj stolik z widokiem na Beskidy</p>
    </div>
  </section>

  <section class="py-20 px-6">
    <div class="max-w-5xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16">

      <!-- Info side -->
      <div>
        <h2 class="font-heading text-3xl font-bold text-primary mb-6">Jak zarezerwować?</h2>
        <p class="text-dark/60 leading-relaxed mb-8">
          Rezerwacji można dokonać telefonicznie lub mailowo. Dla grup powyżej 10 osób
          prosimy o kontakt z wyprzedzeniem — przygotujemy specjalną ofertę.
        </p>

        <div class="space-y-6 mb-10">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-full bg-accent/10 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <h3 class="font-heading text-lg font-semibold text-primary">Telefon</h3>
              <a href={`tel:${info.phone}`} class="text-dark/60 hover:text-accent transition-colors">{info.phone}</a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-full bg-accent/10 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <h3 class="font-heading text-lg font-semibold text-primary">Email</h3>
              <a href={`mailto:${info.email}`} class="text-dark/60 hover:text-accent transition-colors">{info.email}</a>
              <p class="text-sm text-dark/40 mt-1">Temat: "Stara Stacja — rezerwacja"</p>
            </div>
          </div>
        </div>

        <!-- Capacity info -->
        <div class="bg-primary text-white p-8 rounded-sm">
          <h3 class="font-heading text-xl font-semibold mb-4 text-accent">Pojemność</h3>
          <ul class="space-y-3 text-sm">
            <li class="flex justify-between">
              <span class="text-white/70">Wewnątrz</span>
              <span class="font-semibold">{info.capacity.indoor} miejsc</span>
            </li>
            <li class="flex justify-between">
              <span class="text-white/70">Taras</span>
              <span class="font-semibold">{info.capacity.terrace} miejsc</span>
            </li>
            <li class="flex justify-between border-t border-white/10 pt-3">
              <span class="text-white/70">Łącznie</span>
              <span class="font-semibold text-accent">{info.capacity.total} miejsc</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Contact form -->
      <div class="bg-white p-8 lg:p-10 shadow-sm">
        <h2 class="font-heading text-2xl font-bold text-primary mb-6">Formularz rezerwacji</h2>
        <form id="reservation-form" class="space-y-5">
          <div>
            <label for="name" class="block text-sm font-medium text-dark/70 mb-1">Imię i nazwisko</label>
            <input type="text" id="name" name="name" required
              class="w-full px-4 py-3 border border-cream-dark bg-cream/50 focus:border-accent focus:outline-none transition-colors" />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-dark/70 mb-1">Email</label>
            <input type="email" id="email" name="email" required
              class="w-full px-4 py-3 border border-cream-dark bg-cream/50 focus:border-accent focus:outline-none transition-colors" />
          </div>
          <div>
            <label for="phone" class="block text-sm font-medium text-dark/70 mb-1">Telefon</label>
            <input type="tel" id="phone" name="phone"
              class="w-full px-4 py-3 border border-cream-dark bg-cream/50 focus:border-accent focus:outline-none transition-colors" />
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="date" class="block text-sm font-medium text-dark/70 mb-1">Data</label>
              <input type="date" id="date" name="date" required
                class="w-full px-4 py-3 border border-cream-dark bg-cream/50 focus:border-accent focus:outline-none transition-colors" />
            </div>
            <div>
              <label for="guests" class="block text-sm font-medium text-dark/70 mb-1">Liczba gości</label>
              <select id="guests" name="guests" required
                class="w-full px-4 py-3 border border-cream-dark bg-cream/50 focus:border-accent focus:outline-none transition-colors">
                <option value="">Wybierz</option>
                <option value="1-2">1–2</option>
                <option value="3-4">3–4</option>
                <option value="5-8">5–8</option>
                <option value="9-15">9–15</option>
                <option value="16+">16+</option>
              </select>
            </div>
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-dark/70 mb-1">Uwagi</label>
            <textarea id="message" name="message" rows="3"
              class="w-full px-4 py-3 border border-cream-dark bg-cream/50 focus:border-accent focus:outline-none transition-colors resize-none"
              placeholder="Np. rezerwacja kolejki linowej, okazja specjalna..."></textarea>
          </div>
          <button type="submit"
            class="w-full py-4 bg-accent text-primary font-semibold uppercase tracking-wider text-sm hover:bg-accent-light transition-colors">
            Wyślij rezerwację
          </button>
          <p class="text-xs text-dark/40 text-center">Potwierdzenie rezerwacji wyślemy mailem lub telefonicznie.</p>
        </form>
      </div>
    </div>
  </section>

  <!-- Events CTA -->
  <section class="py-20 px-6 bg-cream-dark">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-primary mb-4">Organizujesz wydarzenie?</h2>
      <p class="text-dark/60 max-w-2xl mx-auto mb-8">
        Wesela, konferencje, szkolenia, spotkania firmowe — pomożemy zorganizować
        niezapomniane wydarzenie na szczycie Szyndzielni. Możemy również zorganizować
        rezerwację kolejki linowej w elastycznych godzinach.
      </p>
      <a href="/kontakt" class="inline-block px-10 py-4 bg-primary text-white font-semibold uppercase tracking-wider text-sm hover:bg-primary-light transition-colors">
        Skontaktuj się z nami
      </a>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  const form = document.getElementById('reservation-form') as HTMLFormElement;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();

    const name = (document.getElementById('name') as HTMLInputElement).value;
    const email = (document.getElementById('email') as HTMLInputElement).value;
    const phone = (document.getElementById('phone') as HTMLInputElement).value;
    const date = (document.getElementById('date') as HTMLInputElement).value;
    const guests = (document.getElementById('guests') as HTMLSelectElement).value;
    const message = (document.getElementById('message') as HTMLTextAreaElement).value;

    const subject = `Stara Stacja — rezerwacja ${date}`;
    const body = [
      `Dzień dobry,`,
      ``,
      `Chciałbym/chciałabym zarezerwować stolik:`,
      ``,
      `Imię i nazwisko: ${name}`,
      `Email: ${email}`,
      phone ? `Telefon: ${phone}` : '',
      `Data: ${date}`,
      `Liczba gości: ${guests}`,
      message ? `\nUwagi: ${message}` : '',
      ``,
      `Z poważaniem,`,
      name,
    ].filter(Boolean).join('\n');

    const mailto = `mailto:starastacjabielsko@gmail.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
    window.location.href = mailto;
  });
</script>
