---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import info from '../data/info.json';
---

<Layout title="Rezerwacje — Stara Stacja" description="Zarezerwuj stolik w restauracji Stara Stacja na szczycie Szyndzielni.">
  <Nav />

  <section class="relative pt-32 pb-20 px-6 bg-primary text-white">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-accent-light uppercase tracking-[0.15em] sm:tracking-[0.3em] text-xs sm:text-sm mb-4">Stara Stacja</p>
      <h1 class="font-heading text-5xl md:text-6xl font-bold mb-4">
        <span class="text-pl">Rezerwacje</span>
        <span class="text-en hidden">Reservations</span>
        <span class="text-cs hidden">Rezervace</span>
      </h1>
      <p class="text-white/60 max-w-xl mx-auto">
        <span class="text-pl">Zarezerwuj stolik z widokiem na Beskidy</span>
        <span class="text-en hidden">Book a table with a view of the Beskid Mountains</span>
        <span class="text-cs hidden">Rezervujte si stůl s výhledem na Beskydy</span>
      </p>
    </div>
  </section>

  <section class="py-20 px-6">
    <div class="max-w-5xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16">

      <!-- Info side -->
      <div>
        <h2 class="font-heading text-3xl font-bold text-primary mb-6">
          <span class="text-pl">Jak zarezerwować?</span>
          <span class="text-en hidden">How to book?</span>
          <span class="text-cs hidden">Jak rezervovat?</span>
        </h2>
        <p class="text-dark/60 leading-relaxed mb-8">
          <span class="text-pl">Rezerwacji można dokonać telefonicznie lub mailowo. Dla grup powyżej 10 osób prosimy o kontakt z wyprzedzeniem — przygotujemy specjalną ofertę.</span>
          <span class="text-en hidden">Reservations can be made by phone or email. For groups of more than 10 people, please contact us in advance — we'll prepare a special offer.</span>
          <span class="text-cs hidden">Rezervaci lze provést telefonicky nebo e-mailem. Pro skupiny nad 10 osob nás prosím kontaktujte předem — připravíme speciální nabídku.</span>
        </p>

        <div class="space-y-6 mb-10">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-full bg-accent/10 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <h3 class="font-heading text-lg font-semibold text-primary">
                <span class="text-pl">Telefon</span>
                <span class="text-en hidden">Phone</span>
                <span class="text-cs hidden">Telefon</span>
              </h3>
              <a href={`tel:${info.phone}`} class="text-dark/60 hover:text-accent transition-colors">{info.phone}</a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-full bg-accent/10 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <h3 class="font-heading text-lg font-semibold text-primary">Email</h3>
              <a href={`mailto:${info.email}`} class="text-dark/60 hover:text-accent transition-colors">{info.email}</a>
              <p class="text-sm text-dark/40 mt-1">
                <span class="text-pl">Temat: "Stara Stacja — rezerwacja"</span>
                <span class="text-en hidden">Subject: "Stara Stacja — reservation"</span>
                <span class="text-cs hidden">Předmět: "Stara Stacja — rezervace"</span>
              </p>
            </div>
          </div>
        </div>

        <!-- Capacity info -->
        <div class="bg-primary text-white p-8 rounded-sm">
          <h3 class="font-heading text-xl font-semibold mb-4 text-accent">
            <span class="text-pl">Pojemność</span>
            <span class="text-en hidden">Capacity</span>
            <span class="text-cs hidden">Kapacita</span>
          </h3>
          <ul class="space-y-3 text-sm">
            <li class="flex justify-between">
              <span class="text-white/70">
                <span class="text-pl">Wewnątrz</span>
                <span class="text-en hidden">Indoor</span>
                <span class="text-cs hidden">Uvnitř</span>
              </span>
              <span class="font-semibold">
                <span class="text-pl">{info.capacity.indoor} miejsc</span>
                <span class="text-en hidden">{info.capacity.indoor} seats</span>
                <span class="text-cs hidden">{info.capacity.indoor} míst</span>
              </span>
            </li>
            <li class="flex justify-between">
              <span class="text-white/70">
                <span class="text-pl">Taras</span>
                <span class="text-en hidden">Terrace</span>
                <span class="text-cs hidden">Terasa</span>
              </span>
              <span class="font-semibold">
                <span class="text-pl">{info.capacity.terrace} miejsc</span>
                <span class="text-en hidden">{info.capacity.terrace} seats</span>
                <span class="text-cs hidden">{info.capacity.terrace} míst</span>
              </span>
            </li>
            <li class="flex justify-between border-t border-white/10 pt-3">
              <span class="text-white/70">
                <span class="text-pl">Łącznie</span>
                <span class="text-en hidden">Total</span>
                <span class="text-cs hidden">Celkem</span>
              </span>
              <span class="font-semibold text-accent">
                <span class="text-pl">{info.capacity.total} miejsc</span>
                <span class="text-en hidden">{info.capacity.total} seats</span>
                <span class="text-cs hidden">{info.capacity.total} míst</span>
              </span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Contact form -->
      <div class="bg-white p-8 lg:p-10 shadow-sm">
        <h2 class="font-heading text-2xl font-bold text-primary mb-6">
          <span class="text-pl">Formularz rezerwacji</span>
          <span class="text-en hidden">Reservation form</span>
          <span class="text-cs hidden">Rezervační formulář</span>
        </h2>
        <form id="reservation-form" class="space-y-5">
          <div>
            <label for="name" class="block text-sm font-medium text-dark/70 mb-1">
              <span class="text-pl">Imię i nazwisko</span>
              <span class="text-en hidden">Full name</span>
              <span class="text-cs hidden">Jméno a příjmení</span>
            </label>
            <input type="text" id="name" name="name" required
              class="w-full px-4 py-3 border border-cream-dark bg-cream/50 focus:border-accent focus:outline-none transition-colors" />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-dark/70 mb-1">Email</label>
            <input type="email" id="email" name="email" required
              class="w-full px-4 py-3 border border-cream-dark bg-cream/50 focus:border-accent focus:outline-none transition-colors" />
          </div>
          <div>
            <label for="phone" class="block text-sm font-medium text-dark/70 mb-1">
              <span class="text-pl">Telefon</span>
              <span class="text-en hidden">Phone</span>
              <span class="text-cs hidden">Telefon</span>
            </label>
            <input type="tel" id="phone" name="phone"
              class="w-full px-4 py-3 border border-cream-dark bg-cream/50 focus:border-accent focus:outline-none transition-colors" />
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="date" class="block text-sm font-medium text-dark/70 mb-1">
                <span class="text-pl">Data</span>
                <span class="text-en hidden">Date</span>
                <span class="text-cs hidden">Datum</span>
              </label>
              <input type="date" id="date" name="date" required
                class="w-full px-4 py-3 border border-cream-dark bg-cream/50 focus:border-accent focus:outline-none transition-colors" />
            </div>
            <div>
              <label for="guests" class="block text-sm font-medium text-dark/70 mb-1">
                <span class="text-pl">Liczba gości</span>
                <span class="text-en hidden">Number of guests</span>
                <span class="text-cs hidden">Počet hostů</span>
              </label>
              <select id="guests" name="guests" required
                class="w-full px-4 py-3 border border-cream-dark bg-cream/50 focus:border-accent focus:outline-none transition-colors">
                <option value="">
                  --
                </option>
                <option value="1-2">1–2</option>
                <option value="3-4">3–4</option>
                <option value="5-8">5–8</option>
                <option value="9-15">9–15</option>
                <option value="16+">16+</option>
              </select>
            </div>
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-dark/70 mb-1">
              <span class="text-pl">Uwagi</span>
              <span class="text-en hidden">Notes</span>
              <span class="text-cs hidden">Poznámky</span>
            </label>
            <textarea id="message" name="message" rows="3"
              class="w-full px-4 py-3 border border-cream-dark bg-cream/50 focus:border-accent focus:outline-none transition-colors resize-none"
              placeholder=""></textarea>
          </div>
          <button type="submit"
            class="w-full py-4 bg-accent text-primary font-semibold uppercase tracking-wider text-sm hover:bg-accent-light transition-colors">
            <span class="text-pl">Wyślij rezerwację</span>
            <span class="text-en hidden">Send reservation</span>
            <span class="text-cs hidden">Odeslat rezervaci</span>
          </button>
          <p class="text-xs text-dark/40 text-center">
            <span class="text-pl">Potwierdzenie rezerwacji wyślemy mailem lub telefonicznie.</span>
            <span class="text-en hidden">We'll confirm your reservation by email or phone.</span>
            <span class="text-cs hidden">Potvrzení rezervace vám zašleme e-mailem nebo telefonicky.</span>
          </p>
        </form>
      </div>
    </div>
  </section>

  <!-- Events CTA -->
  <section class="py-20 px-6 bg-cream-dark">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-primary mb-4">
        <span class="text-pl">Organizujesz wydarzenie?</span>
        <span class="text-en hidden">Organizing an event?</span>
        <span class="text-cs hidden">Pořádáte akci?</span>
      </h2>
      <p class="text-dark/60 max-w-2xl mx-auto mb-8">
        <span class="text-pl">Wesela, konferencje, szkolenia, spotkania firmowe — pomożemy zorganizować niezapomniane wydarzenie na szczycie Szyndzielni. Możemy również zorganizować rezerwację kolejki linowej w elastycznych godzinach.</span>
        <span class="text-en hidden">Weddings, conferences, training sessions, corporate meetings — we'll help you organize an unforgettable event at the summit of Szyndzielnia. We can also arrange cable car reservations at flexible hours.</span>
        <span class="text-cs hidden">Svatby, konference, školení, firemní setkání — pomůžeme vám zorganizovat nezapomenutelnou akci na vrcholu Szyndzielnie. Můžeme také zajistit rezervaci lanovky v flexibilních hodinách.</span>
      </p>
      <a href="/eventy" class="inline-block px-10 py-4 bg-primary text-white font-semibold uppercase tracking-wider text-sm hover:bg-primary-light transition-colors">
        <span class="text-pl">Zobacz ofertę eventową</span>
        <span class="text-en hidden">See events offer</span>
        <span class="text-cs hidden">Zobrazit nabídku akcí</span>
      </a>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  const form = document.getElementById('reservation-form') as HTMLFormElement;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();

    const name = (document.getElementById('name') as HTMLInputElement).value;
    const email = (document.getElementById('email') as HTMLInputElement).value;
    const phone = (document.getElementById('phone') as HTMLInputElement).value;
    const date = (document.getElementById('date') as HTMLInputElement).value;
    const guests = (document.getElementById('guests') as HTMLSelectElement).value;
    const message = (document.getElementById('message') as HTMLTextAreaElement).value;

    const subject = `Stara Stacja — rezerwacja ${date}`;
    const body = [
      `Dzień dobry,`,
      ``,
      `Chciałbym/chciałabym zarezerwować stolik:`,
      ``,
      `Imię i nazwisko: ${name}`,
      `Email: ${email}`,
      phone ? `Telefon: ${phone}` : '',
      `Data: ${date}`,
      `Liczba gości: ${guests}`,
      message ? `\nUwagi: ${message}` : '',
      ``,
      `Z poważaniem,`,
      name,
    ].filter(Boolean).join('\n');

    const mailto = `mailto:starastacjabielsko@gmail.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
    window.location.href = mailto;
  });
</script>
