---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import info from '../data/info.json';
---

<Layout title="Kontakt — Stara Stacja" description="Skontaktuj się z restauracją Stara Stacja na Szyndzielni.">
  <Nav />

  <!-- Hero -->
  <section class="relative h-[60vh] min-h-[400px] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-[url('/images/gallery/exterior-summer.jpg')] bg-cover bg-center scale-105" id="kontakt-hero-bg"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-primary/50 via-primary/30 to-primary"></div>
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E');"></div>

    <div class="relative z-10 text-center text-white px-6 max-w-4xl">
      <div class="w-px h-16 bg-accent/40 mx-auto mb-8 reveal-line"></div>
      <p class="text-accent-light uppercase tracking-[0.3em] text-xs sm:text-sm mb-6 reveal-up">Stara Stacja &middot; Szyndzielnia</p>
      <h1 class="font-heading text-5xl sm:text-6xl md:text-7xl font-bold mb-6 reveal-up reveal-delay-1">
        <span class="text-pl">Kontakt</span>
        <span class="text-en hidden">Contact</span>
        <span class="text-cs hidden">Kontakt</span>
      </h1>
      <p class="text-lg font-light text-white/60 max-w-lg mx-auto reveal-up reveal-delay-2">
        <span class="text-pl">Znajdziesz nas na szczycie Szyndzielni</span>
        <span class="text-en hidden">Find us at the summit of Szyndzielnia</span>
        <span class="text-cs hidden">Najdete nás na vrcholu Szyndzielnie</span>
      </p>
    </div>
  </section>

  <!-- Contact cards — mobile-optimized stacked layout -->
  <section class="py-16 sm:py-24 px-4 sm:px-6">
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-6">
        <!-- Address -->
        <a href="https://maps.app.goo.gl/VzaQt8hZ6SY2Dad46" target="_blank" rel="noopener" class="group bg-cream-dark/50 p-6 sm:p-8 border-l-2 border-accent/30 hover:border-accent transition-colors scroll-reveal">
          <div class="w-10 h-10 bg-accent/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <p class="text-[10px] uppercase tracking-[0.2em] text-dark/30 font-semibold mb-2">
            <span class="text-pl">Adres</span>
            <span class="text-en hidden">Address</span>
            <span class="text-cs hidden">Adresa</span>
          </p>
          <p class="text-primary font-heading font-semibold text-sm leading-relaxed group-hover:text-accent transition-colors">
            {info.address.street}<br />
            {info.address.city}
          </p>
        </a>

        <!-- Phone -->
        <a href={`tel:${info.phone}`} class="group bg-cream-dark/50 p-6 sm:p-8 border-l-2 border-accent/30 hover:border-accent transition-colors scroll-reveal">
          <div class="w-10 h-10 bg-accent/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <p class="text-[10px] uppercase tracking-[0.2em] text-dark/30 font-semibold mb-2">
            <span class="text-pl">Telefon</span>
            <span class="text-en hidden">Phone</span>
            <span class="text-cs hidden">Telefon</span>
          </p>
          <p class="text-primary font-heading font-semibold group-hover:text-accent transition-colors">{info.phone}</p>
        </a>

        <!-- Email -->
        <a href={`mailto:${info.email}`} class="group bg-cream-dark/50 p-6 sm:p-8 border-l-2 border-accent/30 hover:border-accent transition-colors scroll-reveal">
          <div class="w-10 h-10 bg-accent/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <p class="text-[10px] uppercase tracking-[0.2em] text-dark/30 font-semibold mb-2">Email</p>
          <p class="text-primary font-heading font-semibold group-hover:text-accent transition-colors text-sm break-all">{info.email}</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Hours -->
  <section class="py-16 sm:py-20 px-4 sm:px-6 bg-cream-dark">
    <div class="max-w-md mx-auto scroll-reveal">
      <div class="text-center mb-8">
        <div class="w-px h-10 bg-accent/30 mx-auto mb-6"></div>
        <h2 class="font-heading text-3xl sm:text-4xl font-bold text-primary">
          <span class="text-pl">Godziny <span class="italic text-accent">otwarcia</span></span>
          <span class="text-en hidden">Opening <span class="italic text-accent">hours</span></span>
          <span class="text-cs hidden">Otevírací <span class="italic text-accent">doba</span></span>
        </h2>
      </div>
      <div class="bg-white p-6 sm:p-8">
        <div class="flex justify-between items-center py-4 border-b border-cream-dark">
          <span class="text-dark/60 text-sm">
            <span class="text-pl">Poniedziałek</span>
            <span class="text-en hidden">Monday</span>
            <span class="text-cs hidden">Pondělí</span>
          </span>
          <span class="font-heading font-bold text-primary">{info.hours.monday}</span>
        </div>
        <div class="flex justify-between items-center py-4">
          <span class="text-dark/60 text-sm">
            <span class="text-pl">Wtorek – Niedziela</span>
            <span class="text-en hidden">Tuesday – Sunday</span>
            <span class="text-cs hidden">Úterý – Neděle</span>
          </span>
          <span class="font-heading font-bold text-primary">{info.hours.tuesday_sunday}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Map -->
  <section class="h-64 sm:h-80 md:h-96 bg-cream-dark">
    <iframe
      src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d1500!2d19.0017352!3d49.7605657!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47141f4663626b0b%3A0x7393f26fe2f2069d!2sKolej+Linowa+Szyndzielnia+g%C3%B3rna+stacja!5e0!3m2!1spl!2spl!4v1"
      width="100%"
      height="100%"
      style="border:0;"
      allowfullscreen=""
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      title="Mapa — Stara Stacja"
    ></iframe>
  </section>

  <!-- How to get here -->
  <section class="py-16 sm:py-24 px-4 sm:px-6">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12 scroll-reveal">
        <div class="w-px h-10 bg-accent/30 mx-auto mb-6"></div>
        <h2 class="font-heading text-3xl sm:text-4xl font-bold text-primary">
          <span class="text-pl">Jak do nas <span class="italic text-accent">dotrzeć</span>?</span>
          <span class="text-en hidden">How to <span class="italic text-accent">get here</span>?</span>
          <span class="text-cs hidden">Jak se k nám <span class="italic text-accent">dostat</span>?</span>
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6">
        <div class="bg-white p-6 sm:p-8 border-t-2 border-accent/30 scroll-reveal">
          <div class="flex items-center gap-3 mb-4">
            <svg class="w-5 h-5 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
            <h3 class="font-heading text-lg font-semibold text-primary">
              <span class="text-pl">Kolejką linową</span>
              <span class="text-en hidden">By cable car</span>
              <span class="text-cs hidden">Lanovkou</span>
            </h3>
          </div>
          <p class="text-dark/50 text-sm leading-relaxed">
            <span class="text-pl">Najwygodniejszy sposób! Kolejka linowa na Szyndzielnię kursuje regularnie. Dla gości restauracji możemy zorganizować rezerwację kolejki w elastycznych godzinach.</span>
            <span class="text-en hidden">The most convenient way! The cable car to Szyndzielnia runs regularly. For restaurant guests, we can arrange cable car reservations at flexible hours.</span>
            <span class="text-cs hidden">Nejpohodlnější způsob! Lanovka na Szyndzielnii jezdí pravidelně. Pro hosty restaurace můžeme zajistit rezervaci lanovky v flexibilních hodinách.</span>
          </p>
        </div>
        <div class="bg-white p-6 sm:p-8 border-t-2 border-accent/30 scroll-reveal">
          <div class="flex items-center gap-3 mb-4">
            <svg class="w-5 h-5 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 21h18M9 8h6m-6 4h6m-6 4h6M5 3h14l-1 18H6L5 3z" /></svg>
            <h3 class="font-heading text-lg font-semibold text-primary">
              <span class="text-pl">Pieszo</span>
              <span class="text-en hidden">On foot</span>
              <span class="text-cs hidden">Pěšky</span>
            </h3>
          </div>
          <p class="text-dark/50 text-sm leading-relaxed">
            <span class="text-pl">Szlaki turystyczne z Bielska-Białej prowadzą na szczyt Szyndzielni. Idealna opcja dla miłośników górskich wędrówek — spacer trwa ok. 1,5–2 godziny.</span>
            <span class="text-en hidden">Hiking trails from Bielsko-Biała lead to the summit of Szyndzielnia. A perfect option for mountain hiking enthusiasts — the walk takes about 1.5–2 hours.</span>
            <span class="text-cs hidden">Turistické stezky z Bielska-Bílé vedou na vrchol Szyndzielnie. Ideální volba pro milovníky horské turistiky — procházka trvá přibližně 1,5–2 hodiny.</span>
          </p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  @keyframes grow-line {
    from { height: 0; opacity: 0; }
    to { height: 4rem; opacity: 1; }
  }
  .reveal-line { animation: grow-line 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards; }

  .reveal-up {
    animation: reveal-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
  }
  .reveal-delay-1 { animation-delay: 0.15s; }
  .reveal-delay-2 { animation-delay: 0.3s; }

  @keyframes reveal-up {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .scroll-reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .scroll-reveal.revealed { opacity: 1; transform: translateY(0); }
</style>

<script>
  // Scroll reveal
  const reveals = document.querySelectorAll('.scroll-reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('revealed');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });
  reveals.forEach((el) => observer.observe(el));

  // Parallax hero (desktop only)
  const heroBg = document.getElementById('kontakt-hero-bg');
  if (heroBg && window.innerWidth > 768) {
    window.addEventListener('scroll', () => {
      const y = window.scrollY;
      if (y < window.innerHeight) {
        heroBg.style.transform = `scale(1.05) translateY(${y * 0.15}px)`;
      }
    }, { passive: true });
  }
</script>
