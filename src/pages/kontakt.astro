---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import info from '../data/info.json';
---

<Layout title="Kontakt — Stara Stacja" description="Skontaktuj się z restauracją Stara Stacja na Szyndzielni.">
  <Nav />

  <section class="relative pt-32 pb-20 px-6 bg-primary text-white">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-accent-light uppercase tracking-[0.15em] sm:tracking-[0.3em] text-xs sm:text-sm mb-4">Stara Stacja</p>
      <h1 class="font-heading text-5xl md:text-6xl font-bold mb-4">
        <span class="text-pl">Kontakt</span>
        <span class="text-en hidden">Contact</span>
        <span class="text-cs hidden">Kontakt</span>
      </h1>
      <p class="text-white/60 max-w-xl mx-auto">
        <span class="text-pl">Znajdziesz nas na szczycie Szyndzielni</span>
        <span class="text-en hidden">Find us at the summit of Szyndzielnia</span>
        <span class="text-cs hidden">Najdete nás na vrcholu Szyndzielnie</span>
      </p>
    </div>
  </section>

  <section class="py-20 px-6">
    <div class="max-w-5xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-12">
      <!-- Address -->
      <div class="text-center lg:text-left">
        <div class="w-14 h-14 mx-auto lg:mx-0 mb-4 rounded-full bg-accent/10 flex items-center justify-center">
          <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        <h3 class="font-heading text-xl font-semibold text-primary mb-2">
          <span class="text-pl">Adres</span>
          <span class="text-en hidden">Address</span>
          <span class="text-cs hidden">Adresa</span>
        </h3>
        <p class="text-dark/60 text-sm leading-relaxed">
          {info.address.street}<br />
          {info.address.city}<br />
          <span class="text-pl">{info.address.country}</span>
          <span class="text-en hidden">Poland</span>
          <span class="text-cs hidden">Polsko</span>
        </p>
      </div>

      <!-- Phone -->
      <div class="text-center lg:text-left">
        <div class="w-14 h-14 mx-auto lg:mx-0 mb-4 rounded-full bg-accent/10 flex items-center justify-center">
          <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
        </div>
        <h3 class="font-heading text-xl font-semibold text-primary mb-2">
          <span class="text-pl">Telefon</span>
          <span class="text-en hidden">Phone</span>
          <span class="text-cs hidden">Telefon</span>
        </h3>
        <a href={`tel:${info.phone}`} class="text-dark/60 hover:text-accent transition-colors">{info.phone}</a>
      </div>

      <!-- Email -->
      <div class="text-center lg:text-left">
        <div class="w-14 h-14 mx-auto lg:mx-0 mb-4 rounded-full bg-accent/10 flex items-center justify-center">
          <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </div>
        <h3 class="font-heading text-xl font-semibold text-primary mb-2">Email</h3>
        <a href={`mailto:${info.email}`} class="text-dark/60 hover:text-accent transition-colors break-all">{info.email}</a>
      </div>
    </div>
  </section>

  <!-- Hours -->
  <section class="py-16 px-6 bg-cream-dark">
    <div class="max-w-md mx-auto text-center">
      <h2 class="font-heading text-3xl font-bold text-primary mb-8">
        <span class="text-pl">Godziny otwarcia</span>
        <span class="text-en hidden">Opening Hours</span>
        <span class="text-cs hidden">Otevírací doba</span>
      </h2>
      <div class="space-y-4">
        <div class="flex justify-between items-center py-3 border-b border-dark/10">
          <span class="text-dark/70">
            <span class="text-pl">Poniedziałek</span>
            <span class="text-en hidden">Monday</span>
            <span class="text-cs hidden">Pondělí</span>
          </span>
          <span class="font-semibold text-primary">{info.hours.monday}</span>
        </div>
        <div class="flex justify-between items-center py-3 border-b border-dark/10">
          <span class="text-dark/70">
            <span class="text-pl">Wtorek – Niedziela</span>
            <span class="text-en hidden">Tuesday – Sunday</span>
            <span class="text-cs hidden">Úterý – Neděle</span>
          </span>
          <span class="font-semibold text-primary">{info.hours.tuesday_sunday}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Map -->
  <section class="h-64 md:h-96 bg-cream-dark">
    <iframe
      src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2573.5!2d19.0!3d49.8!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDnCsDQ4JzAwLjAiTiAxOcKwMDAnMDAuMCJF!5e0!3m2!1spl!2spl!4v1"
      width="100%"
      height="100%"
      style="border:0;"
      allowfullscreen=""
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      title="Mapa — Stara Stacja"
    ></iframe>
  </section>

  <!-- How to get there -->
  <section class="py-20 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-heading text-3xl font-bold text-primary mb-8 text-center">
        <span class="text-pl">Jak do nas dotrzeć?</span>
        <span class="text-en hidden">How to get here?</span>
        <span class="text-cs hidden">Jak se k nám dostat?</span>
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-white p-8 shadow-sm">
          <h3 class="font-heading text-lg font-semibold text-primary mb-3">
            <span class="text-pl">Kolejką linową</span>
            <span class="text-en hidden">By cable car</span>
            <span class="text-cs hidden">Lanovkou</span>
          </h3>
          <p class="text-dark/60 text-sm leading-relaxed">
            <span class="text-pl">Najwygodniejszy sposób! Kolejka linowa na Szyndzielnię kursuje regularnie. Dla gości restauracji możemy zorganizować rezerwację kolejki w elastycznych godzinach.</span>
            <span class="text-en hidden">The most convenient way! The cable car to Szyndzielnia runs regularly. For restaurant guests, we can arrange cable car reservations at flexible hours.</span>
            <span class="text-cs hidden">Nejpohodlnější způsob! Lanovka na Szyndzielnii jezdí pravidelně. Pro hosty restaurace můžeme zajistit rezervaci lanovky v flexibilních hodinách.</span>
          </p>
        </div>
        <div class="bg-white p-8 shadow-sm">
          <h3 class="font-heading text-lg font-semibold text-primary mb-3">
            <span class="text-pl">Pieszo</span>
            <span class="text-en hidden">On foot</span>
            <span class="text-cs hidden">Pěšky</span>
          </h3>
          <p class="text-dark/60 text-sm leading-relaxed">
            <span class="text-pl">Szlaki turystyczne z Bielska-Białej prowadzą na szczyt Szyndzielni. Idealna opcja dla miłośników górskich wędrówek — spacer trwa ok. 1,5–2 godziny.</span>
            <span class="text-en hidden">Hiking trails from Bielsko-Biała lead to the summit of Szyndzielnia. A perfect option for mountain hiking enthusiasts — the walk takes about 1.5–2 hours.</span>
            <span class="text-cs hidden">Turistické stezky z Bielska-Bílé vedou na vrchol Szyndzielnie. Ideální volba pro milovníky horské turistiky — procházka trvá přibližně 1,5–2 hodiny.</span>
          </p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
